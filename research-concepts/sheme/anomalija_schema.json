{
  "$schema": "https://json-schema.org",
  "title": "CivicForensicAnomaly",
  "type": "object",
  "properties": {
    "institution_id": { "type": "string" },
    "document_type": { "type": "string", "enum": ["rješenje", "zaključak", "odgovor", "tender", "studija"] },
    "risk_indicators": {
      "type": "object",
      "properties": {
        "bureaucratic_formalism_score": { "type": "integer", "minimum": 1, "maximum": 10 },
        "accountability_gap_detected": { "type": "boolean" },
        "metadata_mismatch": { "type": "boolean" }
      }
    },
    "narrative_shift_detected": { "type": "string" },
    "public_interest_compliance": { "type": "string", "enum": ["COMPLIANT", "FORMAL_ONLY", "VIOLATED"] }
  }
}
